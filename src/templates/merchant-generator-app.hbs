<form class="merchant-generator-container" autocomplete="off">
  <div class="merchant-generator-form">
    <h3 style="margin:0 0 4px 0;"><i class="fas fa-store"></i> 商人生成器</h3>

    {{!-- 模式选择 --}}
    <div class="merchant-form-group">
      <label>生成模式</label>
      <div class="merchant-mode-toggle">
        <label>
          <input type="radio" name="mode" value="preset" {{#if isPreset}}checked{{/if}} />
          使用预设类型
        </label>
        <label>
          <input type="radio" name="mode" value="custom" {{#if isCustom}}checked{{/if}} />
          自定义配置
        </label>
        <button type="button" class="merchant-open-config-btn" title="管理预设类型">
          <i class="fas fa-cog"></i> 管理预设
        </button>
      </div>
    </div>

    {{!-- 商人名称 --}}
    <div class="merchant-form-group">
      <label>商人名称</label>
      <input type="text" name="merchantName" value="{{merchantName}}" placeholder="留空使用类型名称或默认名称" />
    </div>

    {{!-- ===== 预设模式 ===== --}}
    {{#if isPreset}}
      {{#if hasTypes}}
      <div class="merchant-form-group">
        <label>选择商人类型</label>
        <select name="selectedTypeId">
          {{#each typeOptions}}
            <option value="{{this.id}}" {{#if this.selected}}selected{{/if}}>
              {{this.name}}{{#if this.description}} - {{this.description}}{{/if}}
            </option>
          {{/each}}
        </select>
      </div>
      {{else}}
      <div class="merchant-form-group">
        <p class="merchant-empty-hint">暂无预设商人类型。请点击"管理预设"创建商人类型，或切换到"自定义配置"模式。</p>
      </div>
      {{/if}}
    {{/if}}

    {{!-- ===== 自定义模式 ===== --}}
    {{#if isCustom}}
      <div class="merchant-form-group">
        <label>内容类型</label>
        <div class="merchant-checkbox-group">
          {{#each contentTypeOptions}}
            <label>
              <input type="checkbox" name="contentType" value="{{this.value}}" {{#if this.checked}}checked{{/if}} />
              {{this.label}}
            </label>
          {{/each}}
        </div>
      </div>

      {{#if showFeatCategories}}
      <div class="merchant-form-group">
        <label>专长子分类 <span class="merchant-hint">（不勾选则包含所有）</span></label>
        <div class="merchant-checkbox-group merchant-sub-categories">
          {{#each featCategoryOptions}}
            <label>
              <input type="checkbox" name="featCategory" value="{{this.value}}" {{#if this.checked}}checked{{/if}} />
              {{this.label}}
            </label>
          {{/each}}
        </div>
      </div>
      {{/if}}

      {{#if showEquipmentCategories}}
      <div class="merchant-form-group">
        <label>装备子分类 <span class="merchant-hint">（不勾选则包含所有）</span></label>
        <div class="merchant-checkbox-group merchant-sub-categories">
          {{#each equipmentCategoryOptions}}
            <label>
              <input type="checkbox" name="equipmentCategory" value="{{this.value}}" {{#if this.checked}}checked{{/if}} />
              {{this.label}}
            </label>
          {{/each}}
        </div>
      </div>
      {{/if}}

      <div class="merchant-form-row">
        <div class="merchant-form-group">
          <label>最低等级</label>
          <input type="number" name="levelMin" value="{{levelMin}}" min="0" max="25" />
        </div>
        <div class="merchant-form-group">
          <label>最高等级</label>
          <input type="number" name="levelMax" value="{{levelMax}}" min="0" max="25" />
        </div>
      </div>

      <div class="merchant-form-row">
        <div class="merchant-form-group">
          <label>最少商品数</label>
          <input type="number" name="itemCountMin" value="{{itemCountMin}}" min="1" max="100" />
        </div>
        <div class="merchant-form-group">
          <label>最多商品数</label>
          <input type="number" name="itemCountMax" value="{{itemCountMax}}" min="1" max="100" />
        </div>
      </div>

      <div class="merchant-form-group">
        <label>价格倍率</label>
        <input type="number" name="priceMultiplier" value="{{priceMultiplier}}" min="0.1" max="10" step="0.1" />
      </div>

      <div class="merchant-form-group">
        <label>稀有度 <span class="merchant-hint">（不勾选则包含所有）</span></label>
        <div class="merchant-checkbox-group">
          {{#each rarityOptions}}
            <label>
              <input type="checkbox" name="rarity" value="{{this.value}}" {{#if this.checked}}checked{{/if}} />
              {{this.label}}
            </label>
          {{/each}}
        </div>
      </div>

      <div class="merchant-form-group">
        <label>必须包含的特征</label>
        <div class="merchant-tag-input" data-field="requiredTraits">
          {{#each requiredTraitLabels}}
            <span class="merchant-tag">{{this.label}} <i class="fas fa-times remove-tag" data-tag="{{this.value}}"></i></span>
          {{/each}}
          <input type="text" placeholder="输入后按回车添加..." class="merchant-tag-text-input" data-field="requiredTraits" list="merchant-gen-traits-datalist" autocomplete="off" />
        </div>
      </div>

      <div class="merchant-form-group">
        <label>必须排除的特征</label>
        <div class="merchant-tag-input" data-field="excludedTraits">
          {{#each excludedTraitLabels}}
            <span class="merchant-tag">{{this.label}} <i class="fas fa-times remove-tag" data-tag="{{this.value}}"></i></span>
          {{/each}}
          <input type="text" placeholder="输入后按回车排除..." class="merchant-tag-text-input" data-field="excludedTraits" list="merchant-gen-traits-datalist" autocomplete="off" />
        </div>
      </div>

      <datalist id="merchant-gen-traits-datalist">
        {{#each availableTraits}}
          <option value="{{this.label}}">{{this.label}} ({{this.value}})</option>
        {{/each}}
      </datalist>

      {{#if hasBanlists}}
      <div class="merchant-form-group">
        <label>应用屏蔽列表</label>
        <div class="merchant-checkbox-group">
          {{#each banlistOptions}}
            <label>
              <input type="checkbox" name="banList" value="{{this.id}}" {{#if this.checked}}checked{{/if}} />
              {{this.name}} <span class="merchant-hint">({{this.itemCount}} 项)</span>
            </label>
          {{/each}}
        </div>
      </div>
      {{/if}}

      <div class="merchant-form-group">
        <label>卷轴名称前缀</label>
        <input type="text" name="scrollPrefix" value="{{scrollPrefix}}" placeholder="学习卷轴：" />
      </div>
    {{/if}}

    {{!-- 宏代码预览 --}}
    <div class="merchant-form-group">
      <label><i class="fas fa-code"></i> 生成的宏代码</label>
      <div class="merchant-code-preview">{{macroCode}}</div>
    </div>
  </div>

  {{!-- 操作按钮 --}}
  <div class="merchant-generator-actions">
    <button class="merchant-generate-btn" type="button">
      <i class="fas fa-store"></i> 生成商人
    </button>
    <button class="merchant-copy-code-btn" type="button">
      <i class="fas fa-copy"></i> 复制代码
    </button>
    <button class="merchant-create-macro-btn" type="button">
      <i class="fas fa-plus"></i> 创建宏
    </button>
  </div>
</form>
