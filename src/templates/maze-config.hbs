<div class="maze-config">

  {{!-- ====== Phase 1: Prompt Input (always visible) ====== --}}
  <div class="maze-prompt-section">
    <div class="maze-prompt-header">
      <i class="fas fa-dungeon"></i>
      <span>描述你想要的迷宫</span>
    </div>
    <textarea name="mazeDescription" rows="4" placeholder="例如：一个 4×4 的地下城迷宫，入口在西北角，有一条蜿蜒的走廊通向东南角的 Boss 大厅，中间穿过一个陷阱房和一个宝库，走廊用门连接各房间...">{{mazeDescription}}</textarea>
    <div class="maze-prompt-actions">
      <button type="button" class="maze-generate-btn" {{#if isGenerating}}disabled{{/if}}>
        <i class="fas {{#if isGenerating}}fa-spinner fa-spin{{else}}fa-magic{{/if}}"></i>
        {{#if isGenerating}}生成中...{{else}}生成迷宫{{/if}}
      </button>
      <button type="button" class="maze-advanced-toggle" title="高级配置">
        <i class="fas fa-sliders-h"></i>
      </button>
    </div>
  </div>

  {{!-- ====== Advanced Config (collapsed by default) ====== --}}
  <div class="maze-advanced-panel" style="display:none;">
    <div class="maze-adv-row">
      <label>宽度</label>
      <input type="number" name="mazeWidth" value="{{config.mazeWidth}}" min="2" max="10" />
      <label>高度</label>
      <input type="number" name="mazeHeight" value="{{config.mazeHeight}}" min="2" max="10" />
    </div>
    <div class="maze-adv-row">
      <label>模板尺寸</label>
      <select name="templateCellSize">
        {{#each templateSizeOptions}}
        <option value="{{this.cellSize}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
        {{/each}}
      </select>
    </div>
    <div class="maze-adv-row">
      <label>
        <input type="checkbox" name="wallMergeEnabled" {{#if config.wallMergeEnabled}}checked{{/if}} />
        墙体合并
      </label>
    </div>
  </div>

  {{!-- ====== Phase 2: Results (only after generation) ====== --}}
  {{#if hasResult}}

  {{!-- AI Reasoning --}}
  {{#if reasoning}}
  <div class="maze-reasoning-block">
    <div class="maze-reasoning-header"><i class="fas fa-lightbulb"></i> 设计思路</div>
    <p>{{reasoning}}</p>
  </div>
  {{/if}}

  {{!-- Template Gallery: what AI designed --}}
  <div class="maze-section-label"><i class="fas fa-puzzle-piece"></i> AI 设计的模板 ({{templateCards.length}})</div>
  <div class="maze-template-gallery">
    {{#each templateCards}}
    <div class="maze-tpl-card">
      <canvas class="maze-tpl-thumb" data-tpl-idx="{{@index}}" width="80" height="80"></canvas>
      <div class="maze-tpl-info">
        <span class="maze-tpl-name">{{this.name}}</span>
        <span class="maze-tpl-type" style="color:{{this.typeColor}};">{{this.typeLabel}}</span>
      </div>
    </div>
    {{/each}}
  </div>

  {{!-- Maze Layout Preview --}}
  <div class="maze-section-label"><i class="fas fa-map"></i> 迷宫布局 ({{previewHint}})</div>
  <div class="maze-preview-area">
    <canvas id="maze-preview-canvas" width="480" height="480"></canvas>
  </div>
  {{#if connectivityWarnings}}
  <div class="maze-warn-bar">
    <i class="fas fa-exclamation-triangle"></i> {{connectivityWarnings}} 处连通性不一致
  </div>
  {{/if}}

  {{!-- Modify --}}
  <div class="maze-modify-section">
    <textarea name="modifyDescription" rows="2" placeholder="不满意？输入修改要求，如：把走廊变窄、增加一个暗门..."></textarea>
    <div class="maze-modify-actions">
      <button type="button" class="maze-modify-btn" {{#if isGenerating}}disabled{{/if}}>
        <i class="fas fa-sync-alt"></i> 修改
      </button>
    </div>
  </div>

  {{!-- Save / Place --}}
  <div class="maze-bottom-bar">
    <div class="maze-bottom-bar-left">
    <input type="text" name="blueprintName" value="{{blueprintName}}" placeholder="蓝图名称" />
    </div>
    <div class="maze-bottom-bar-right">
    <button type="button" class="maze-save-btn"><i class="fas fa-save"></i> 保存</button>
    <button type="button" class="maze-place-btn"><i class="fas fa-map-marker-alt"></i> 放置</button>
    </div>
  </div>

  {{/if}}
</div>
