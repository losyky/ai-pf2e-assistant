<div class="map-tile-gallery">
  <div class="gallery-hint">
    <i class="fas fa-info-circle"></i> 点击图块放置到场景（复用已有图片，无需重新生成）
  </div>

  {{#if hasAnyTiles}}
  {{#each groups}}
  <div class="tile-group">
    {{#unless ../filterTemplateName}}
    <div class="group-header">
      <i class="fas fa-layer-group"></i>
      <span class="group-name">{{this.templateName}}</span>
      <span class="group-count">{{this.count}} 张</span>
    </div>
    {{/unless}}
    <div class="tile-grid">
      {{#each this.tiles}}
      <div class="tile-item" data-template-id="{{this.templateId}}" data-path="{{this.path}}" title="{{this.filename}}">
        <div class="tile-preview">
          <img src="{{this.path}}" alt="{{this.filename}}" loading="lazy" />
        </div>
        <div class="tile-overlay">
          <span class="tile-time">{{this.timeLabel}}</span>
          <div class="tile-btns">
            <button class="tile-btn" data-action="place" data-template-id="{{this.templateId}}" data-path="{{this.path}}" title="放置到场景">
              <i class="fas fa-crosshairs"></i>
            </button>
            <button class="tile-btn danger" data-action="delete" data-path="{{this.path}}" title="删除此图块">
              <i class="fas fa-trash"></i>
            </button>
          </div>
        </div>
      </div>
      {{/each}}
    </div>
  </div>
  {{/each}}
  {{else}}
  <div class="empty-state">
    <i class="fas fa-images"></i>
    <p>暂无已生成的图块</p>
    <p class="gallery-empty-hint">拖入模板到场景以生成新图块</p>
  </div>
  {{/if}}
</div>
